[Unit]
Description=BolideOS Shell (combined launcher + settings)
Requires=dbus.socket
ConditionUser=!root

[Service]
Type=notify
WorkingDirectory=/
EnvironmentFile=-/var/lib/environment/compositor/*.conf
ExecStartPre=/usr/bin/bolide-launcher-precondition
ExecStartPre=-/bin/sh -ec '/bin/echo QUIT > /run/psplash_fifo'
ExecStart=/usr/bin/bolide-shell $LIPSTICK_OPTIONS --systemd
TimeoutStopSec=3
Restart=always

[Install]
WantedBy=default.target
